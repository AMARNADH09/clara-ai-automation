# Clara Answers — Environment Variables
# Copy this file to .env and fill in values

# n8n basic auth (protect the UI)
N8N_USER=admin
N8N_PASSWORD=change_me_before_deploy

# Timezone for the n8n container
# Use a standard TZ identifier: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=America/New_York

# Optional: Path to the project root (used by run scripts if needed)
CLARA_PROJECT_ROOT=/data/clara-pipeline
